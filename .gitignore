# private/user data: keep folders, ignore contents
data/raw/*
!data/raw/.gitkeep
data/raster/*
!data/raster/.gitkeep
data/rasters/*
!data/rasters/.gitkeep

# generated outputs: keep pretrained model included in this release
outputs/*
!outputs/.gitkeep
!outputs/pretrained_model/
!outputs/pretrained_model/**

# logs and executed notebooks
logs/
*_executed.ipynb

# notebook checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/
